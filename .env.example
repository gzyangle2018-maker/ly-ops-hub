# ============================================================
# LY-OPS Hub — Environment Variables (Phase 1)
# 复制此文件为 .env 并根据需要修改
# ============================================================

VITE_APP_NAME=LY-OPS Hub
VITE_PUBLIC_SITE_URL=
VITE_HUB_URL=

# 认证开关 (Phase 1 = false)
VITE_AUTH_ENABLED=false

# 默认 LLM Provider
VITE_DEFAULT_LLM_PROVIDER=custom-relay
VITE_DEFAULT_LLM_MODEL=

# 库存备货助手入口
VITE_STOCK_HELPER_URL=https://amazon-stock-helper.pages.dev
VITE_STOCK_HELPER_GITHUB=https://github.com/gzyangle2018-maker/amazon-inventory-assistant-20260528-v3-success

# 后端 API (Phase 2)
VITE_API_BASE_URL=

# Supabase (Phase 2)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
